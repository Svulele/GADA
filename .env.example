PORT=3000
NODE_ENV=development

# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-this-with-a-long-random-string

# Optional. Leave blank to use local SQLite gada.db.
# In production, set this to your hosted Postgres connection string.
DATABASE_URL=

# Optional. Use one of these for hosted config instead of committing config.json.
# CONFIG_JSON_PATH=./config.json
# CONFIG_JSON={"locations":["Reception","Ward A"],"users":[{"id":"admin","name":"Admin","role":"Admin","department":"Admin","access":"admin","pin":"0000"}]}
